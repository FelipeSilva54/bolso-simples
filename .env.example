# Firebase — copie este arquivo para .env.local e preencha com os valores do Firebase Console
# Projeto > Configurações do projeto > Seus apps > App da Web (ou leia google-services.json)

EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Google Sign-In — Firebase Console > Authentication > Sign-in method > Google > Web client ID
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
